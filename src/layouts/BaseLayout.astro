---
// src/layouts/BaseLayout.astro
import '@fontsource-variable/inter'
import '@/styles/global.css'

interface Props {
    title?: string
    description?: string
    canonical?: string
}
const {
    title = 'extreweb — Diseño y desarrollo web en Extremadura',
    description = 'Agencia de diseño, desarrollo web, SEO y soporte técnico en Don Benito, Villanueva de la Serena y Cáceres.',
    canonical,
} = Astro.props

const canonicalURL =
    canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).href
---

<!doctype html>
<html lang='es'>
    <head>
        <meta charset='UTF-8' />
        <script is:inline>
            ;(function () {
                try {
                    var t = localStorage.getItem('theme')
                    if (
                        t === 'dark' ||
                        (!t &&
                            matchMedia('(prefers-color-scheme: dark)').matches)
                    )
                        document.documentElement.setAttribute(
                            'data-theme',
                            'dark',
                        )
                } catch (e) {}
                var d = document.documentElement
                if (matchMedia('(prefers-reduced-motion: reduce)').matches)
                    return
                d.classList.add('js-motion')
                setTimeout(function () {
                    if (!d.hasAttribute('data-motion-ready'))
                        d.classList.remove('js-motion')
                }, 2500)
            })()
        </script>
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
        <meta name='generator' content={Astro.generator} />
        <meta name='theme-color' content='#ffffff' />

        <title>{title}</title>
        <meta name='description' content={description} />
        <link rel='canonical' href={canonicalURL} />

        <meta property='og:type' content='website' />
        <meta property='og:title' content={title} />
        <meta property='og:description' content={description} />
        <meta property='og:url' content={canonicalURL} />
        <meta property='og:locale' content='es_ES' />
        <meta name='twitter:card' content='summary_large_image' />
    </head>
    <body>
        <!-- Custom Cursor -->
        <div class="custom-cursor" id="custom-cursor" aria-hidden="true"></div>
        <slot />

        <script>
            // @ts-nocheck
            import { spring } from '@/lib/motion.js'
            import '@/lib/motion.js'

            // --- Lógica del Cursor Personalizado ---
            const cursor = document.getElementById('custom-cursor');
            
            // Solo activamos en dispositivos con ratón preciso
            if (window.matchMedia('(pointer: fine)').matches && cursor) {
                // Instanciamos el resorte físico para X e Y
                const cursorX = spring((v) => { cursor.style.left = `${v}px` }, { stiffness: 0.15, damping: 0.75 });
                const cursorY = spring((v) => { cursor.style.top = `${v}px` }, { stiffness: 0.15, damping: 0.75 });
                
                let isInit = false;
                
                window.addEventListener('mousemove', (e) => {
                    if (!isInit) {
                        cursor.style.opacity = '1';
                        // Posición inicial instantánea para evitar que vuele desde la esquina 0,0
                        cursor.style.left = `${e.clientX}px`;
                        cursor.style.top = `${e.clientY}px`;
                        isInit = true;
                    }
                    // Le decimos al resorte cuál es el nuevo objetivo
                    cursorX.set(e.clientX);
                    cursorY.set(e.clientY);
                });

                // Detectar interactividad (enlaces, botones) usando event delegation
                document.addEventListener('mouseover', (e) => {
                    if (e.target.closest('a, button, input, textarea, select, [role="button"]')) {
                        cursor.classList.add('is-hovering');
                    }
                });
                document.addEventListener('mouseout', (e) => {
                    if (e.target.closest('a, button, input, textarea, select, [role="button"]')) {
                        cursor.classList.remove('is-hovering');
                    }
                });
            }
        </script>
    </body>
</html>
