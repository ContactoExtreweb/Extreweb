---
// src/components/Projects.astro
const proyectos = [
    {
        num: '01',
        nombre: 'GuadiCar Multimarcas',
        desc: 'Plataforma para un concesionario: catálogo dinámico, fichas detalladas y panel de gestión.',
        tags: ['Astro', 'Supabase', 'Netlify'],
        url: 'https://guadicar.es',
        img: '/proyectos/Guadicar.webp',
    },
    {
        num: '02',
        nombre: 'Toldos Pallares',
        desc: 'Web corporativa para una empresa de toldos y protección solar, con catálogo de productos.',
        tags: ['WordPress', 'Elementor'],
        url: 'https://toldospallares.com',
        img: '/proyectos/Toldos-Pallares.webp',
    },
    {
        num: '03',
        nombre: 'CarMeet ESP',
        desc: 'Comunidad para aficionados al motor: eventos, quedadas y mapa interactivo.',
        tags: ['React', 'Supabase', 'Leaflet'],
        url: 'https://carmeet.es',
        img: '/proyectos/Car-MeetESP.webp',
    },
    {
        num: '04',
        nombre: 'Fichar365',
        desc: 'Aplicación web a medida.',
        tags: ['Web app'],
        url: 'https://fichar365.com',
        img: '/proyectos/Fichar.webp',
    },

    {
        num: '05',
        nombre: 'Taller Chapa y Pintura M.Guzmán',
        desc: 'Aplicación web a medida.',
        tags: ['Web app'],
        url: 'https://project-r5m3o.vercel.app/',
        img: '/proyectos/Guzman.webp',
    },
]
---

<section class='hproj' id='hproj'>
    <div class='hproj-track'>
        <div class='hproj-panel hproj-intro'>
            <span class='mono text-accent'>Proyectos</span>
            <h2>Trabajo real,<br />en producción</h2>
            <p>Algunos de los proyectos que ya están online y funcionando.</p>
            <span class='hproj-hint'>Desliza →</span>
        </div>

        {
            proyectos.map((p) => (
                <article class='hproj-panel hproj-card'>
                    <a
                        href={p.url}
                        target='_blank'
                        rel='noopener'
                        class='hproj-frame'
                    >
                        {p.img ? (
                            <img src={p.img} alt={p.nombre} />
                        ) : (
                            <span class='hproj-ph'>{p.nombre}</span>
                        )}
                    </a>
                    <div class='hproj-info'>
                        <span class='mono text-accent'>{p.num}</span>
                        <h3>{p.nombre}</h3>
                        <p>{p.desc}</p>
                        <div class='hproj-tags'>
                            {p.tags.map((t) => (
                                <span class='hproj-tag'>{t}</span>
                            ))}
                        </div>
                        <a
                            href={p.url}
                            target='_blank'
                            rel='noopener'
                            class='hproj-link'
                        >
                            Ver web ↗
                        </a>
                    </div>
                </article>
            ))
        }
    </div>
</section>

<style>
    .hproj {
        min-height: 100vh;
        overflow: hidden;
        background: var(--bg);
        display: flex;
        align-items: center;
    }
    .hproj-track {
        display: flex;
        align-items: center;
        gap: clamp(2rem, 5vw, 5rem);
        padding-inline: clamp(1.5rem, 8vw, 9rem);
    }
    .hproj-panel {
        flex-shrink: 0;
    }

    /* Intro */
    .hproj-intro {
        width: min(520px, 85vw);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
    }
    .hproj-intro h2 {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
    }
    .hproj-intro p {
        color: var(--muted);
        font-size: 1.1rem;
    }
    .hproj-hint {
        font-weight: 600;
        color: var(--accent);
        margin-top: 0.5rem;
    }

    /* Tarjeta */
    .hproj-card {
        width: min(460px, 80vw);
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }
    .hproj-frame {
        display: flex;
        align-items: center;
        justify-content: center;
        aspect-ratio: 16 / 11;
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition:
            transform 0.4s ease,
            box-shadow 0.4s ease;
    }
    .hproj-card:hover .hproj-frame {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
    }
    .hproj-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
    }
    .hproj-ph {
        font-weight: 600;
        font-size: clamp(1.2rem, 3vw, 1.8rem);
        color: var(--muted);
        text-align: center;
        padding: 1rem;
    }

    .hproj-info {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .hproj-info h3 {
        font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    }
    .hproj-info p {
        color: var(--muted);
        font-size: 0.98rem;
    }
    .hproj-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.3rem;
    }
    .hproj-tag {
        font-size: 0.72rem;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 980px;
        padding: 0.2rem 0.7rem;
    }
    .hproj-link {
        margin-top: 0.5rem;
        color: var(--accent);
        font-weight: 500;
        font-size: 0.95rem;
    }

    /* Móvil: pila vertical, sin scroll horizontal */
    /* Móvil: carrusel deslizable con el dedo (swipe + snap) */
    @media (max-width: 767px) {
        .hproj {
            min-height: auto;
            display: block;
            padding-block: clamp(3.5rem, 10vh, 5rem);
        }
        .hproj-track {
            flex-direction: row;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-padding-left: var(--pad);
            gap: 1rem;
            padding-inline: var(--pad);
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .hproj-track::-webkit-scrollbar {
            display: none;
        }
        .hproj-intro,
        .hproj-card {
            width: 82vw;
        }
        .hproj-panel {
            scroll-snap-align: start;
        }
        .hproj-frame {
            aspect-ratio: 16 / 10;
        }
    }
</style>

<script>
    // @ts-nocheck
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (!reduce) {
        if (window.innerWidth >= 768) {
            // ESCRITORIO: la sección se fija y la fila se mueve en horizontal con el scroll
            const track = document.querySelector('.hproj-track')
            const amount = () => track.scrollWidth - window.innerWidth

            gsap.to(track, {
                x: () => -amount(),
                ease: 'none',
                scrollTrigger: {
                    trigger: '.hproj',
                    start: 'top top',
                    end: () => '+=' + amount(),
                    scrub: 1,
                    pin: true,
                    anticipatePin: 1,
                    invalidateOnRefresh: true,
                },
            })
        } else {
            // MÓVIL: revelado en cascada
            gsap.from('.hproj-panel', {
                scrollTrigger: { trigger: '.hproj', start: 'top 80%' },
                y: 40,
                autoAlpha: 0,
                stagger: 0.1,
                duration: 0.7,
                ease: 'power3.out',
            })
        }
    }
</script>
