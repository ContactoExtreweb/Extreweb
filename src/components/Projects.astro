---
// src/components/Projects.astro
const projects = [
    {
        title: 'CarMeet',
        category: 'Comunidad Automotriz',
        image: '/proyectos/Car-MeetESP.webp',
        link: 'https://carmeet.es',
        color: '#f43f5e'
    },
    {
        title: 'Fichar365',
        category: 'SaaS / RRHH',
        image: '/proyectos/Fichar.webp',
        link: 'https://fichar365.com',
        color: '#3b82f6'
    },
    {
        title: 'Guadicar Multimarcas',
        category: 'Concesionario',
        image: '/proyectos/Guadicar.webp',
        link: 'https://guadicar.es',
        color: '#eab308'
    },
    {
        title: 'Taller M. Guzmán',
        category: 'Automoción',
        image: '/proyectos/Guzman.webp',
        link: 'https://project-r5m3o.vercel.app/',
        color: '#10b981'
    },
    {
        title: 'Toldos Pallares',
        category: 'Web Corporativa',
        image: '/proyectos/Toldos-Pallares.webp',
        link: 'https://toldospallares.com',
        color: '#a855f7'
    }
]
---

<section class='projects' id='proyectos'>
    <div class='container p-head'>
        <span class='eyebrow'>Nuestro Trabajo</span>
        <h2>Proyectos que<br />marcan la diferencia.</h2>
    </div>

    <!-- Contenedor que se fijará (pin) durante el scroll -->
    <div class='projects-wrapper'>
        <div class='projects-track'>
            
            {projects.map((p, i) => (
                <div class='project-card'>
                    <div class='p-image'>
                        <img src={p.image} alt={p.title} loading="lazy" />
                        <div class='p-overlay' style={`--hover-c: ${p.color}`}>
                            <a href={p.link} target="_blank" rel="noopener noreferrer" class='p-btn'>Visitar proyecto</a>
                        </div>
                    </div>
                    <div class='p-info'>
                        <span class='p-cat'>{p.category}</span>
                        <h3>{p.title}</h3>
                    </div>
                </div>
            ))}

            <!-- Card final de Call to Action -->
            <div class='projects-end'>
                <div class='end-content'>
                    <div class='end-icon'>
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 16 16 12 12 8"></polyline><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                    </div>
                    <h3>¿Tienes un proyecto en mente?</h3>
                    <p>Hablemos sobre cómo podemos escalar tu negocio al siguiente nivel.</p>
                    <a href='/proyectos' class='btn btn-accent btn-large'>Ver todos los proyectos</a>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .projects {
        padding: clamp(80px, 12vh, 140px) 0;
        background: var(--bg);
        overflow: hidden;
        position: relative;
    }
    
    .p-head {
        margin-bottom: clamp(2rem, 5vh, 4rem);
    }
    .eyebrow {
        color: var(--accent);
        font-weight: 600;
        font-size: 0.95rem;
        letter-spacing: 0.05em;
        margin-bottom: 0.8rem;
        display: block;
        text-transform: uppercase;
    }
    .p-head h2 {
        font-size: clamp(2.8rem, 6vw, 4.5rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        line-height: 1.05;
        color: var(--fg);
    }

    /* --- HORIZONTAL SCROLL TRACK --- */
    .projects-wrapper {
        height: 80vh; 
        min-height: 500px;
        display: flex;
        align-items: center;
        /* En escritorio no tiene overflow porque GSAP mueve el track */
    }
    .projects-track {
        display: flex;
        gap: clamp(2rem, 5vw, 6rem);
        padding: 0 10vw; /* Margen inicial para que la primera tarjeta no esté pegada al borde */
        width: max-content;
        align-items: center;
    }

    /* --- CARDS --- */
    .project-card {
        width: 55vw;
        max-width: 900px;
        min-width: 320px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .p-image {
        width: 100%;
        aspect-ratio: 16 / 10;
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        transform: translateZ(0); /* Forzar aceleración hardware */
    }
    .p-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform;
    }
    
    /* Overlay y Botón al hacer Hover */
    .p-overlay {
        position: absolute;
        inset: 0;
        background: color-mix(in srgb, var(--hover-c) 20%, rgba(0,0,0,0.4));
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.5s ease;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }
    .p-btn {
        background: #fff;
        color: #000;
        padding: 1rem 2rem;
        border-radius: 100px;
        font-weight: 600;
        font-size: 1.05rem;
        transform: translateY(20px);
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
    }
    html[data-theme='light'] .p-btn {
        background: #000;
        color: #fff;
    }
    
    /* Efectos Hover Desktop */
    @media (hover: hover) {
        .project-card:hover .p-image img {
            transform: scale(1.06);
        }
        .project-card:hover .p-overlay {
            opacity: 1;
        }
        .project-card:hover .p-btn {
            transform: translateY(0);
        }
    }

    .p-info {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .p-cat {
        font-size: 0.95rem;
        font-weight: 500;
        color: #86868b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .p-info h3 {
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--fg);
    }

    /* --- END CARD CTA --- */
    .projects-end {
        width: 40vw;
        min-width: 320px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4rem;
    }
    .end-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1.5rem;
    }
    .end-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }
    .end-content h3 {
        font-size: clamp(2rem, 3vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        color: var(--fg);
    }
    .end-content p {
        color: #86868b;
        font-size: 1.15rem;
        max-width: 400px;
        margin-bottom: 1rem;
    }
    .btn-large {
        padding: 1rem 2.5rem;
        font-size: 1.1rem;
    }

    /* --- RESPONSIVE MOBILE --- */
    @media (max-width: 768px) {
        .project-card {
            width: 85vw;
        }
        .projects-end {
            width: 85vw;
            padding: 0 1rem;
        }
        .p-btn { display: none; }
    }
</style>

<script>
    // @ts-nocheck
    import { gsap, ScrollTrigger, reduceMotion } from '@/lib/motion.js'

    if (!reduceMotion) {
        const wrapper = document.querySelector('.projects-wrapper');
        const track = document.querySelector('.projects-track');
        
        if (wrapper && track) {
            // Función para calcular la distancia a desplazar
            const getScrollAmount = () => -(track.scrollWidth - window.innerWidth);
            
            const tween = gsap.to(track, {
                x: getScrollAmount,
                ease: "none"
            });

            ScrollTrigger.create({
                trigger: wrapper,
                start: "center center",      // Cuando el contenedor llega al centro de la pantalla
                end: () => `+=${track.scrollWidth - window.innerWidth}`, // Hacer scroll la misma distancia que la anchura sobrante
                pin: true,                   // Fijar la sección
                animation: tween,
                scrub: 1,                    // Suavizado del scroll
                invalidateOnRefresh: true,   // Recalcular medidas al redimensionar la ventana
            });
        }
    }
</script>
