---
// src/components/Navbar.astro
const links = [
    { href: '/servicios', label: 'Servicios' },
    { href: '/proyectos', label: 'Proyectos' },
    { href: '/nosotros', label: 'Nosotros' },
]
const path = Astro.url.pathname
---

<div class='nav-container'>
    <header class='smart-nav' id='smartNav'>
        <div class='nav-inner'>
            <!-- Logo (Texto 'extreweb' visible siempre) -->
            <a href='/' class='logo' aria-label='Inicio extreweb'>
                <span class='logo-mark'>E</span>
                <span class='logo-text'>extreweb</span>
            </a>

            <!-- Enlaces PC -->
            <nav class='desktop-links'>
                {
                    links.map((l) => (
                        <a
                            href={l.href}
                            class:list={[
                                'nav-link',
                                { active: path === l.href },
                            ]}
                        >
                            {l.label}
                        </a>
                    ))
                }
            </nav>

            <!-- Acciones -->
            <div class='nav-actions'>
                <button
                    class='theme-btn'
                    id='themeBtn'
                    aria-label='Cambiar tema'
                >
                    <svg
                        class='ico-sun'
                        width='18'
                        height='18'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2'
                        stroke-linecap='round'
                        ><circle cx='12' cy='12' r='4'></circle><path
                            d='M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4'
                        ></path></svg
                    >
                    <svg
                        class='ico-moon'
                        width='18'
                        height='18'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        ><path d='M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z'
                        ></path></svg
                    >
                </button>
                <a href='/contacto' class='btn btn-accent nav-cta hide-mobile'
                    >Hablemos</a
                >

                <!-- Hamburguesa animada (Solo móvil) -->
                <button
                    class='burger'
                    id='burger'
                    aria-label='Abrir menú'
                    aria-expanded='false'
                >
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>
    </header>
</div>

<!-- Menú Inmersivo a pantalla completa -->
<div class='fullscreen-menu' id='mobileMenu'>
    <div class='menu-bg' aria-hidden='true'></div>
    <nav class='menu-content'>
        <div class='menu-links'>
            <a href='/' class:list={['m-link', { active: path === '/' }]}
                >Inicio</a
            >
            {
                links.map((l) => (
                    <a
                        href={l.href}
                        class:list={['m-link', { active: path === l.href }]}
                    >
                        {l.label}
                    </a>
                ))
            }
        </div>
        <div class='menu-footer'>
            <a href='/contacto' class='btn btn-accent btn-large'
                >Empezar proyecto</a
            >
            <div class='menu-contact'>
                <p>hola@extreweb.es</p>
                <p>628 77 56 19</p>
            </div>
        </div>
    </nav>
</div>

<style>
    /* ── CONTENEDOR Y PASTILLA INTELIGENTE ── */
    .nav-container {
        position: fixed;
        top: clamp(12px, 2vh, 20px);
        left: 0;
        width: 100%;
        z-index: 100; /* Siempre por encima del menú móvil */
        pointer-events: none;
        display: flex;
        justify-content: center;
        padding-inline: var(--pad);
    }

    .smart-nav {
        pointer-events: auto;
        width: 100%;
        max-width: 980px;
        background: color-mix(in srgb, var(--surface) 80%, transparent);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border: 1px solid var(--border);
        border-radius: var(--radius-pill);
        padding: 6px 6px 6px 18px;
        box-shadow: var(--shadow);

        transition:
            box-shadow 0.4s ease,
            padding 0.4s ease;
    }

    /* Estado Scrolleado */
    .smart-nav.is-scrolled {
        box-shadow: var(--shadow-lg);
        background: color-mix(in srgb, var(--surface) 95%, transparent);
    }

    .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 52px;
    }

    /* ── ELEMENTOS INTERNOS ── */
    .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
        transition: transform var(--dur-fast) ease;
    }
    .logo:active {
        transform: scale(0.95);
    }
    .logo-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 8px;
        background: var(--accent);
        color: var(--accent-fg);
        font-size: 1.05rem;
        font-weight: 700;
    }

    .desktop-links {
        display: flex;
        align-items: center;
        gap: 2rem;
    }
    .nav-link {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--muted);
        transition: color var(--dur-mid) ease;
        position: relative;
    }
    .nav-link.active {
        color: var(--fg);
        font-weight: 600;
    }
    .nav-link::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -4px;
        width: 100%;
        height: 2px;
        background: var(--accent);
        transform: scaleX(0);
        transition: transform var(--dur-mid) var(--ease-out-quart);
        border-radius: 2px;
    }
    .nav-link.active::after {
        transform: scaleX(1);
    }
    @media (hover: hover) {
        .nav-link:hover {
            color: var(--fg);
        }
        .nav-link:hover::after {
            transform: scaleX(1);
            opacity: 0.4;
        }
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .nav-cta {
        padding: 0.5rem 1.2rem;
        font-size: 0.9rem;
    }

    /* Theme Toggle */
    .theme-btn {
        display: grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        color: var(--fg);
        transition:
            background var(--dur-mid) ease,
            transform var(--dur-fast);
    }
    .theme-btn:active {
        transform: scale(0.9);
    }
    @media (hover: hover) {
        .theme-btn:hover {
            background: color-mix(in srgb, var(--border) 40%, transparent);
        }
    }
    .ico-moon {
        display: none;
    }
    html[data-theme='dark'] .ico-sun {
        display: none;
    }
    html[data-theme='dark'] .ico-moon {
        display: block;
    }

    /* Burger Animada */
    .burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 44px;
        height: 44px;
        position: relative;
        background: var(--surface);
        border-radius: 50%;
        border: 1px solid var(--border);
        transition: transform 0.2s ease;
    }
    .burger:active {
        transform: scale(0.9);
    }
    .burger span {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--fg);
        border-radius: 2px;
        margin: 0 auto;
        transition:
            transform 0.3s var(--ease-out-quart),
            opacity 0.2s ease;
    }
    /* Animación a 'X' */
    .burger.is-open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }
    .burger.is-open span:nth-child(2) {
        opacity: 0;
    }
    .burger.is-open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* ── MENÚ MÓVIL INMERSIVO ── */
    .fullscreen-menu {
        position: fixed;
        inset: 0;
        z-index: 90; /* Por debajo de nav-container (100) */
        display: flex;
        flex-direction: column;
        pointer-events: none;
        visibility: hidden;
    }
    .fullscreen-menu.is-open {
        pointer-events: auto;
        visibility: visible;
    }

    .menu-bg {
        position: absolute;
        inset: 0;
        background: var(--bg);
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    /* Añadimos un poco de desenfoque al fondo para asegurar la legibilidad */
    html[data-theme='dark'] .menu-bg {
        background: rgba(0, 0, 0, 0.95);
    }
    html[data-theme='light'] .menu-bg {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .fullscreen-menu.is-open .menu-bg {
        opacity: 1;
    }

    .menu-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 100px var(--pad) 2rem; /* Espacio superior para no pisar la pastilla */
    }

    .menu-links {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }
    .m-link {
        font-size: clamp(2rem, 6vw, 2.8rem); /* Tamaño ajustado y centrado */
        font-weight: 600;
        letter-spacing: -0.04em;
        color: var(--muted);
        transform: translateY(20px);
        opacity: 0;
        transition:
            color 0.3s ease,
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            opacity 0.5s ease;
    }
    .m-link.active {
        color: var(--fg);
    }

    /* Efecto Cascada al abrir */
    .fullscreen-menu.is-open .m-link {
        transform: translateY(0);
        opacity: 1;
    }
    .fullscreen-menu.is-open .m-link:nth-child(1) {
        transition-delay: 0.1s;
    }
    .fullscreen-menu.is-open .m-link:nth-child(2) {
        transition-delay: 0.15s;
    }
    .fullscreen-menu.is-open .m-link:nth-child(3) {
        transition-delay: 0.2s;
    }
    .fullscreen-menu.is-open .m-link:nth-child(4) {
        transition-delay: 0.25s;
    }

    .menu-footer {
        margin-top: 3.5rem;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.5s ease 0.3s;
        width: 100%;
        max-width: 320px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }
    .fullscreen-menu.is-open .menu-footer {
        opacity: 1;
        transform: translateY(0);
    }

    .btn-large {
        display: flex;
        justify-content: center;
        font-size: 1.05rem;
        padding: 1rem;
        width: 100%;
    }

    .menu-contact {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    .menu-contact p {
        color: var(--muted);
        font-weight: 500;
        font-size: 0.95rem;
        letter-spacing: 0.02em;
    }

    /* ── RESPONSIVE COMPORTAMIENTO ── */
    @media (max-width: 820px) {
        .hide-mobile {
            display: none !important;
        }
        .desktop-links {
            display: none;
        }
        .burger {
            display: flex;
        }

        /* En móvil ajustamos la pastilla para que quepa todo */
        .smart-nav {
            padding: 4px 4px 4px 12px;
        }
    }
</style>

<script>
    // @ts-nocheck
    const nav = document.getElementById('smartNav')
    const burger = document.getElementById('burger')
    const mobileMenu = document.getElementById('mobileMenu')

    let isMenuOpen = false

    // 1. STICKY HEADER LOGIC (Solo añade sombra al bajar)
    const handleScroll = () => {
        if (isMenuOpen) return
        nav.classList.toggle('is-scrolled', window.scrollY > 20)
    }

    window.addEventListener('scroll', handleScroll, { passive: true })

    // 2. LÓGICA DEL MENÚ MÓVIL
    const toggleMenu = () => {
        isMenuOpen = !isMenuOpen
        burger.classList.toggle('is-open', isMenuOpen)
        mobileMenu.classList.toggle('is-open', isMenuOpen)
        burger.setAttribute('aria-expanded', String(isMenuOpen))

        // Bloquear scroll de la página al abrir
        document.body.style.overflow = isMenuOpen ? 'hidden' : ''
    }

    burger?.addEventListener('click', toggleMenu)

    // Cerrar menú al tocar un enlace
    mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
            if (isMenuOpen) toggleMenu()
        })
    })

    // 3. CAMBIO DE TEMA
    const themeBtn = document.getElementById('themeBtn')
    themeBtn?.addEventListener('click', () => {
        const dark =
            document.documentElement.getAttribute('data-theme') === 'dark'
        document.documentElement.setAttribute(
            'data-theme',
            dark ? 'light' : 'dark',
        )
        try {
            localStorage.setItem('theme', dark ? 'light' : 'dark')
        } catch (e) {}
    })
</script>
