---
// src/components/PageHero.astro
interface Props {
    label: string
    intro?: string
}
const { label, intro } = Astro.props
---

<section class='page-hero'>
    <div class='container'>
        <span class='mono text-accent'>{label}</span>
        <h1 class='page-hero-title'><slot /></h1>
        {intro && <p class='page-hero-intro text-muted'>{intro}</p>}
    </div>
</section>

<style>
    .page-hero {
        padding-top: clamp(8rem, 18vh, 12rem);
        padding-bottom: clamp(2.5rem, 6vw, 4rem);
    }
    .page-hero-title {
        margin: 1rem 0;
        font-size: clamp(2.8rem, 9vw, 6rem);
    }
    .page-hero-intro {
        font-size: 1.2rem;
        max-width: 55ch;
    }
</style>

<script>
    // @ts-nocheck
    import { gsap } from 'gsap'
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    gsap.set('.page-hero', { autoAlpha: 1 })

    if (!reduce) {
        gsap.from('.page-hero .container > *', {
            y: 24,
            autoAlpha: 0,
            stagger: 0.1,
            duration: 0.7,
            ease: 'power3.out',
        })
    }
</script>
