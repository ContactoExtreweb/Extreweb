---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class='site-footer'>
    <div class='container'>
        <div class='f-top'>
            <!-- Brand -->
            <div class='f-brand'>
                <a href="/" class="logo">
                    <span class="logo-mark">
                        <!-- Icono Rayo Premium -->
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    </span>
                    <span class="logo-text">Extreweb</span>
                </a>
                <p>Ingeniería digital premium desde Extremadura.<br />Diseñando el futuro de internet, una línea de código a la vez.</p>
                
                <div class="f-socials">
                    <a href="#" aria-label="Twitter"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg></a>
                    <a href="#" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
                    <a href="#" aria-label="LinkedIn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
                </div>
            </div>
            
            <!-- Links -->
            <div class='f-links'>
                <div class='f-col'>
                    <h4>Navegación</h4>
                    <ul>
                        <li><a href='/'>Inicio</a></li>
                        <li><a href='/servicios'>Servicios</a></li>
                        <li><a href='/proyectos'>Proyectos</a></li>
                        <li><a href='/nosotros'>Nosotros</a></li>
                    </ul>
                </div>
                <div class='f-col'>
                    <h4>Expertise</h4>
                    <ul>
                        <li><a href='#'>Diseño UI/UX</a></li>
                        <li><a href='#'>Desarrollo Headless</a></li>
                        <li><a href='#'>E-commerce Avanzado</a></li>
                        <li><a href='#'>SEO Técnico</a></li>
                    </ul>
                </div>
                <div class='f-col'>
                    <h4>Contacto</h4>
                    <ul>
                        <li><a href='mailto:hola@extreweb.es'>hola@extreweb.es</a></li>
                        <li><a href='tel:+34600000000'>+34 600 000 000</a></li>
                        <li><a href='/contacto' class='link-accent'>Agendar llamada &rarr;</a></li>
                    </ul>
                </div>
            </div>
        </div>
        
        <!-- Big Typography Decoration -->
        <div class="f-big-text">
            <span>EXTREWEB</span>
        </div>
        
        <!-- Bottom / Legal -->
        <div class='f-bottom'>
            <p>&copy; {currentYear} Extreweb. Todos los derechos reservados.</p>
            <div class='f-legal'>
                <a href='#'>Aviso Legal</a>
                <a href='#'>Privacidad</a>
                <a href='#'>Cookies</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: var(--bg);
        padding-top: clamp(80px, 12vh, 140px);
        overflow: hidden;
        position: relative;
        border-top: 1px solid var(--border);
    }
    
    .f-top {
        display: flex;
        justify-content: space-between;
        gap: 4rem;
        flex-wrap: wrap;
        margin-bottom: clamp(4rem, 8vh, 6rem);
    }
    
    /* --- BRAND --- */
    .f-brand {
        flex: 1;
        min-width: 300px;
        max-width: 400px;
    }
    .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--fg);
        text-decoration: none;
        font-weight: 700;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
        margin-bottom: 1.5rem;
    }
    .logo-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: var(--fg);
        color: var(--bg);
        border-radius: 8px;
    }
    .f-brand p {
        color: #86868b;
        line-height: 1.6;
        font-size: 1.05rem;
        margin-bottom: 2rem;
    }
    .f-socials {
        display: flex;
        gap: 1rem;
    }
    .f-socials a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid var(--border);
        color: var(--fg);
        transition: all 0.3s ease;
    }
    @media (hover: hover) {
        .f-socials a:hover {
            border-color: var(--accent);
            color: var(--accent);
            transform: translateY(-3px);
        }
    }
    
    /* --- LINKS --- */
    .f-links {
        display: flex;
        gap: clamp(3rem, 6vw, 6rem);
        flex-wrap: wrap;
    }
    .f-col {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .f-col h4 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--fg);
    }
    .f-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .f-col a {
        color: #86868b;
        text-decoration: none;
        transition: color 0.3s ease;
        font-size: 1rem;
    }
    @media (hover: hover) {
        .f-col a:hover {
            color: var(--fg);
        }
    }
    .link-accent {
        color: var(--accent) !important;
        font-weight: 600;
    }
    
    /* --- BIG TEXT --- */
    .f-big-text {
        text-align: center;
        overflow: hidden;
        user-select: none;
        line-height: 0.8;
        padding-bottom: 2rem;
    }
    .f-big-text span {
        font-size: clamp(4rem, 15vw, 16rem);
        font-weight: 900;
        letter-spacing: -0.05em;
        background: linear-gradient(180deg, color-mix(in srgb, var(--fg) 10%, transparent) 0%, transparent 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* --- BOTTOM --- */
    .f-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        color: #86868b;
        font-size: 0.9rem;
    }
    .f-legal {
        display: flex;
        gap: 1.5rem;
    }
    .f-legal a {
        color: #86868b;
        text-decoration: none;
        transition: color 0.3s ease;
    }
    @media (hover: hover) {
        .f-legal a:hover {
            color: var(--fg);
        }
    }

    /* Mobile */
    @media (max-width: 768px) {
        .f-top {
            flex-direction: column;
            gap: 3rem;
        }
        .f-links {
            gap: 2.5rem;
            flex-direction: column;
        }
        .f-bottom {
            flex-direction: column;
            text-align: center;
            justify-content: center;
        }
    }
</style>
