---
// src/pages/proyectos.astro
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/PageHero.astro'

// Usa las MISMAS rutas de imagen que ya pusiste en el home (Projects.astro).
// Si las nombraste distinto, ajusta el campo img.
const proyectos = [
    {
        num: '01',
        nombre: 'GuadiCar Multimarcas',
        desc: 'Plataforma para un concesionario de vehículos de ocasión. Catálogo dinámico, buscador con fichas detalladas y panel de gestión.',
        tags: ['Astro', 'Supabase', 'Netlify'],
        url: 'https://guadicar.es',
        urlLabel: 'guadicar.es',
        img: '/proyectos/Guadicar.webp',
    },
    {
        num: '02',
        nombre: 'Toldos Pallares',
        desc: 'Web corporativa para una empresa de toldos y protección solar. Diseño a medida, catálogo de productos y formulario de contacto.',
        tags: ['WordPress', 'Elementor'],
        url: 'https://toldospallares.com',
        urlLabel: 'toldospallares.com',
        img: '/proyectos/Toldos-Pallares.webp',
    },
    {
        num: '03',
        nombre: 'CarMeet ESP',
        desc: 'Comunidad para aficionados al motor: eventos, quedadas y perfiles de vehículos, con mapa interactivo e inscripciones.',
        tags: ['React', 'Supabase', 'Leaflet'],
        url: 'https://carmeet.es',
        urlLabel: 'carmeet.es',
        img: '/proyectos/Car-MeetESP.webp',
    },
    {
        num: '04',
        nombre: 'Fichar365',
        desc: 'Aplicación web a medida.',
        tags: ['Web app'],
        url: 'https://fichar365.com',
        urlLabel: 'fichar365.com',
        img: '/proyectos/Fichar.webp',
    },
]
---

<BaseLayout
    title='Proyectos — extreweb'
    description='Proyectos web en producción: concesionarios, e-commerce y aplicaciones a medida. Casos reales de diseño y desarrollo en Extremadura.'
>
    <PageHero
        label='// proyectos'
        intro='Webs y aplicaciones reales funcionando para negocios reales. Sin maquetas: esto es lo que hacemos.'
    >
        Trabajo que ya está <em class='text-accent'>online</em>
    </PageHero>

    <main>
        <section class='projects-page'>
            <div class='container'>
                <div class='projects-page-grid'>
                    {
                        proyectos.map((p) => (
                            <a
                                href={p.url}
                                target='_blank'
                                rel='noopener'
                                class='project-card'
                            >
                                <div class='project-card-frame'>
                                    {p.img ? (
                                        <img src={p.img} alt={p.nombre} />
                                    ) : (
                                        <span class='project-card-placeholder'>
                                            {p.nombre}
                                        </span>
                                    )}
                                </div>
                                <div class='project-card-info'>
                                    <span class='mono project-card-num text-accent'>
                                        {p.num} · Proyecto
                                    </span>
                                    <h2 class='project-card-name'>
                                        {p.nombre}
                                    </h2>
                                    <p class='project-card-desc'>{p.desc}</p>
                                    <div class='project-card-tags'>
                                        {p.tags.map((t) => (
                                            <span class='project-card-tag'>
                                                {t}
                                            </span>
                                        ))}
                                    </div>
                                    <span class='project-card-link mono'>
                                        Ver web — {p.urlLabel} ↗
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .projects-page-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: clamp(2rem, 4vw, 3.5rem);
    }

    .project-card {
        display: flex;
        flex-direction: column;
        color: var(--fg);
    }

    .project-card-frame {
        border: var(--border-w) solid var(--fg);
        box-shadow: var(--shadow);
        background: var(--surface);
        aspect-ratio: 16 / 10;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 1.3rem;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }
    .project-card:hover .project-card-frame {
        transform: translate(-5px, -5px);
        box-shadow: 12px 12px 0 var(--accent);
    }
    .project-card-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .project-card-placeholder {
        font-weight: 700;
        font-size: clamp(1.3rem, 3vw, 2rem);
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: -0.02em;
        text-align: center;
        padding: 1rem;
    }

    .project-card-info {
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    .project-card-num {
        font-size: 0.75rem;
    }
    .project-card-name {
        font-size: clamp(1.5rem, 3vw, 2.2rem);
        margin: 0.4rem 0 0.6rem;
    }
    .project-card-desc {
        color: var(--muted);
        margin-bottom: 0.9rem;
        font-size: 0.98rem;
    }

    .project-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.2rem;
    }
    .project-card-tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg);
        border: 1px solid var(--muted);
        padding: 0.25rem 0.6rem;
    }

    .project-card-link {
        margin-top: auto;
        padding-bottom: 2px;
        width: fit-content;
        border-bottom: 2px solid var(--accent);
        transition: color 0.2s ease;
    }
    .project-card:hover .project-card-link {
        color: var(--accent);
    }

    @media (max-width: 768px) {
        .projects-page-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
    }
</style>

<script>
    // @ts-nocheck
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (!reduce) {
        gsap.from('.project-card', {
            scrollTrigger: { trigger: '.projects-page-grid', start: 'top 80%' },
            y: 40,
            autoAlpha: 0,
            stagger: 0.12,
            duration: 0.7,
            ease: 'power3.out',
        })
    }
</script>
