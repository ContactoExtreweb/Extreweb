---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/Navbar.astro'
import Footer from '@/components/Footer.astro'

const seoTitle = 'Contacto — extreweb, tu agencia web'
const seoDesc =
    'Habla directamente con los fundadores de extreweb. Cuéntanos tu proyecto y veamos cómo podemos ayudarte a crecer en internet.'
---

<BaseLayout title={seoTitle} description={seoDesc}>
    <Navbar />

    <main class='page-main'>
        <div class='ambient-glow g-1'></div>

        <section class='contact-sec'>
            <div class='container'>
                <div class='contact-grid'>
                    <!-- LADO IZQUIERDO: Info y Mensaje -->
                    <div class='c-left'>
                        <span class='eyebrow gsap-fade'>¿Hablamos?</span>
                        <h1 class='gsap-reveal'>Cuéntanos tu<br />proyecto.</h1>
                        <p class='c-desc gsap-fade'>
                            Sin compromisos ni chatbots. Cuéntanos qué necesitas
                            y te responderemos en menos de 24 horas. También
                            puedes enviarnos un WhatsApp si lo prefieres.
                        </p>

                        <div class='c-info-list gsap-fade'>
                            <div class='c-info-item'>
                                <span class='c-icon'>✉️</span>
                                <div>
                                    <strong>Email directo</strong>
                                    <a href='mailto:contacto@extreweb.es'
                                        >contacto@extreweb.es</a
                                    >
                                </div>
                            </div>
                            <div class='c-info-item'>
                                <span class='c-icon'>💬</span>
                                <div>
                                    <strong>WhatsApp / Teléfono</strong>
                                    <a href='tel:+34628775619'
                                        >+34 628 775 619</a
                                    >
                                </div>
                            </div>
                            <div class='c-info-item'>
                                <span class='c-icon'>📍</span>
                                <div>
                                    <strong>Sede Principal</strong>
                                    <span
                                        >Villanueva de la Serena, Extremadura</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- LADO DERECHO: Formulario Conversacional -->
                    <div class='c-right gsap-up'>
                        <div class='form-card'>
                            <form
                                name='contacto'
                                method='POST'
                                data-netlify='true'
                                netlify-honeypot='bot-field'
                                class='extre-form'
                            >
                                <p class='hp-field'>
                                    <label
                                        >No rellenar este campo si eres humano: <input
                                            name='bot-field'
                                        /></label
                                    >
                                </p>

                                <div class='form-group'>
                                    <label for='name'>Me llamo...</label>
                                    <input
                                        type='text'
                                        id='name'
                                        name='name'
                                        placeholder='Tu nombre o empresa'
                                        required
                                    />
                                </div>

                                <div class='form-group'>
                                    <label for='email'>Mi email es...</label>
                                    <input
                                        type='email'
                                        id='email'
                                        name='email'
                                        placeholder='correo@ejemplo.com'
                                        required
                                    />
                                </div>

                                <div class='form-group'>
                                    <label for='service'>Me interesa...</label>
                                    <div class='select-wrapper'>
                                        <select id='service' name='service'>
                                            <option value='web'
                                                >Diseño y Desarrollo Web</option
                                            >
                                            <option value='seo'
                                                >SEO / Posicionamiento</option
                                            >
                                            <option value='social'
                                                >Redes Sociales</option
                                            >
                                            <option value='sistemas'
                                                >Sistemas y Soporte</option
                                            >
                                            <option value='otro'
                                                >Otra consulta</option
                                            >
                                        </select>
                                    </div>
                                </div>

                                <div class='form-group'>
                                    <label for='message'
                                        >Y me gustaría contaros que...</label
                                    >
                                    <textarea
                                        id='message'
                                        name='message'
                                        rows='4'
                                        placeholder='Háblanos un poco de tu negocio y lo que tienes en mente...'
                                        required></textarea>
                                </div>

                                <div class='form-action'>
                                    <button
                                        type='submit'
                                        class='btn btn-accent btn-massive'
                                    >
                                        Enviar Mensaje <span>→</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</BaseLayout>

<style>
    .page-main {
        background: var(--bg);
        overflow-x: hidden;
        position: relative;
    }

    .ambient-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
        z-index: 0;
        pointer-events: none;
    }
    .g-1 {
        width: 600px;
        height: 600px;
        background: var(--accent);
        top: 0;
        right: -200px;
    }
    html[data-theme='light'] .ambient-glow {
        opacity: 0.08;
    }

    .contact-sec {
        padding: clamp(150px, 20vh, 200px) 0 clamp(80px, 10vh, 120px);
        position: relative;
        z-index: 10;
        min-height: 90vh;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(4rem, 8vw, 8rem);
        align-items: start;
    }

    /* --- LADO IZQUIERDO --- */
    .eyebrow {
        color: var(--accent);
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        display: block;
        margin-bottom: 2rem;
    }
    .c-left h1 {
        font-size: clamp(3rem, 6vw, 5.5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.05;
        margin-bottom: 2rem;
        color: var(--fg);
    }
    .c-desc {
        font-size: clamp(1.2rem, 2vw, 1.4rem);
        line-height: 1.6;
        color: var(--muted);
        margin-bottom: 4rem;
        max-width: 500px;
    }

    .c-info-list {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }
    .c-info-item {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
    }
    .c-icon {
        font-size: 2rem;
        line-height: 1;
        background: var(--surface);
        padding: 1rem;
        border-radius: 20px;
        border: 1px solid var(--border);
    }
    .c-info-item div {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }
    .c-info-item strong {
        font-size: 1.1rem;
        color: var(--fg);
    }
    .c-info-item a,
    .c-info-item span {
        font-size: 1.2rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    .c-info-item a:hover {
        color: var(--accent);
    }

    /* --- LADO DERECHO (FORMULARIO) --- */
    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 32px;
        padding: clamp(2.5rem, 5vw, 4rem);
        box-shadow: var(--shadow-lg);
    }

    .extre-form {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-group label {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--fg);
        letter-spacing: -0.02em;
    }

    .extre-form input,
    .extre-form textarea,
    .extre-form select {
        width: 100%;
        background: var(--bg);
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 1.2rem 1.5rem;
        font-family: var(--font);
        font-size: 1.1rem;
        color: var(--fg);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .extre-form input:focus,
    .extre-form textarea:focus,
    .extre-form select:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
        transform: translateY(-2px);
    }

    .extre-form textarea {
        resize: vertical;
        min-height: 120px;
    }

    .select-wrapper {
        position: relative;
    }
    .select-wrapper::after {
        content: '↓';
        position: absolute;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.2rem;
        color: var(--muted);
        pointer-events: none;
    }
    .extre-form select {
        appearance: none;
        padding-right: 3rem;
        cursor: pointer;
    }

    .form-action {
        margin-top: 1rem;
    }
    .btn-massive {
        width: 100%;
        justify-content: center;
        font-size: 1.3rem;
        padding: 1.2rem 2rem;
        border-radius: 20px;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 900px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 5rem;
        }
        .form-card {
            padding: 2rem;
            border-radius: 24px;
        }
    }
</style>

<script>
    // @ts-nocheck
    import { gsap } from '@/lib/motion.js'

    document.addEventListener('DOMContentLoaded', () => {
        gsap.from('.gsap-reveal', {
            y: 40,
            opacity: 0,
            duration: 1,
            ease: 'power4.out',
            delay: 0.1,
        })
        gsap.from('.gsap-fade', {
            y: 20,
            opacity: 0,
            duration: 1,
            stagger: 0.15,
            ease: 'power3.out',
            delay: 0.2,
        })
        gsap.from('.gsap-up', {
            y: 60,
            opacity: 0,
            duration: 1.2,
            ease: 'power4.out',
            delay: 0.4,
        })
    })
</script>
