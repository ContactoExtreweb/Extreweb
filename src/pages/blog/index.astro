---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/Navbar.astro'
import Cta from '@/components/Cta.astro'
import Footer from '@/components/Footer.astro'
import { getCollection } from 'astro:content'

const seoTitle = "Blog de Diseño Web y SEO | extreweb";
const seoDesc = "Artículos, guías y consejos sobre diseño web, posicionamiento SEO, rendimiento y marketing digital para empresas.";

// Obtenemos los artículos reales de la colección "blog"
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={seoTitle} description={seoDesc}>
    <Navbar />
    <main class="page-main">
        <div class="ambient-glow g-1"></div>

        <section class="blog-hero text-center">
            <div class="container">
                <span class="eyebrow gsap-fade">Nuestro Blog</span>
                <h1 class="gsap-reveal">Pensamientos,<br/><span class="text-accent">Código y SEO.</span></h1>
                <p class="hero-desc gsap-fade">
                    Escribimos sobre lo que mejor sabemos hacer: crear negocios digitales de éxito. Consejos prácticos, tutoriales de código y las últimas tendencias en posicionamiento.
                </p>
            </div>
        </section>

        <section class="blog-grid-sec">
            <div class="container">
                <div class="blog-grid">
                    {posts.map((post, i) => (
                        <a href={`/blog/${post.id}`} class="b-card gsap-up" style={`transition-delay: ${i * 0.1}s`}>
                            <div class="b-img">
                                <img src={post.data.heroImage || "https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=800&q=80"} alt={post.data.title} loading="lazy" />
                                <div class="b-cat">{post.data.category}</div>
                            </div>
                            <div class="b-content">
                                <div class="b-date">
                                    {post.data.pubDate.toLocaleDateString('es-ES', {
                                        year: 'numeric',
                                        month: 'short',
                                        day: 'numeric',
                                    })}
                                </div>
                                <h2>{post.data.title}</h2>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <Cta />
    </main>
    <Footer />
</BaseLayout>

<style>
    .page-main { background: var(--bg); overflow-x: hidden; position: relative; }
    .text-center { text-align: center; }

    .ambient-glow {
        position: absolute; border-radius: 50%; filter: blur(120px);
        opacity: 0.15; z-index: 0; pointer-events: none;
    }
    .g-1 {
        width: 600px; height: 600px; background: var(--accent);
        top: -100px; left: 50%; transform: translateX(-50%);
    }
    html[data-theme='light'] .ambient-glow { opacity: 0.08; }

    .blog-hero {
        padding: clamp(160px, 20vh, 220px) 0 clamp(60px, 10vh, 100px);
        position: relative; z-index: 10;
    }
    .eyebrow {
        color: var(--accent); font-weight: 600; letter-spacing: 0.1em;
        text-transform: uppercase; display: block; margin-bottom: 2rem;
    }
    .blog-hero h1 {
        font-size: clamp(3rem, 6vw, 5.5rem); font-weight: 800;
        line-height: 1.05; margin-bottom: 2rem; color: var(--fg);
    }
    .hero-desc {
        font-size: clamp(1.2rem, 2vw, 1.4rem); line-height: 1.6;
        color: var(--muted); max-width: 700px; margin: 0 auto;
    }

    .blog-grid-sec {
        padding-bottom: clamp(100px, 15vh, 150px);
        position: relative; z-index: 10;
    }
    .blog-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem;
    }

    .b-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        overflow: hidden;
        text-decoration: none;
        transition: transform 0.4s var(--ease-out-quart), border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .b-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent);
        box-shadow: var(--shadow-lg);
    }

    .b-img {
        width: 100%;
        height: 300px;
        position: relative;
        overflow: hidden;
    }
    .b-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s var(--ease-out-quart);
    }
    .b-card:hover .b-img img {
        transform: scale(1.05);
    }
    
    .b-cat {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .b-content {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .b-date {
        color: var(--muted);
        font-size: 0.95rem;
        font-family: var(--font-mono, monospace);
    }
    .b-content h2 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--fg);
        line-height: 1.3;
        margin: 0;
        letter-spacing: -0.02em;
        transition: color 0.3s ease;
    }
    .b-card:hover .b-content h2 {
        color: var(--accent);
    }

    @media (max-width: 900px) {
        .blog-grid { grid-template-columns: 1fr; gap: 2rem; }
        .b-img { height: 250px; }
        .b-content { padding: 1.5rem; }
    }
</style>

<script>
    // @ts-nocheck
    import { gsap } from '@/lib/motion.js'
    document.addEventListener('DOMContentLoaded', () => {
        gsap.from(".gsap-reveal", { y: 40, opacity: 0, duration: 1, ease: "power4.out", delay: 0.1 });
        gsap.from(".gsap-fade", { y: 20, opacity: 0, duration: 1, stagger: 0.15, ease: "power3.out", delay: 0.2 });
        gsap.utils.toArray('.gsap-up').forEach((el) => {
            gsap.from(el, {
                scrollTrigger: { trigger: el, start: "top 85%" },
                y: 50, opacity: 0, duration: 0.8, ease: "power3.out"
            });
        });
    });
</script>
